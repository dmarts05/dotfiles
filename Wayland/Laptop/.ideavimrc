set clipboard=unnamedplus,unnamed,ideaput " Integrate with system clipboard
set hlsearch " Highlight search occurrences
set ignorecase " Ignore case in search patterns
set smartcase " No ignore case when pattern is uppercase

set commentary " gc to comment/uncomment lines
set surround " Surround plugin
set highlightedyank
let g:highlightedyank_highlight_duration = "100"
let g:highlightedyank_highlight_color = "rgba(202, 166, 247, 100)"

" Custom mappings
let mapleader = " "

nnoremap <leader>q :q<CR>
nnoremap <leader>h :nohlsearch<CR>

nmap <leader>lr :action RenameElement<CR>

nnoremap <c-o> :action Back<cr>
nnoremap <c-i> :action Forward<cr>

nmap <leader>c :action CloseContent<CR>
nmap <leader>bb :action PreviousTab<CR>
nmap <leader>bn :action NextTab<CR>
nmap <leader>wh :action SplitHorizontally<CR>
nmap <leader>wv :action SplitVertically<CR>

nmap <leader>p :action SearchEverywhere<CR>
nmap <leader>s :action SearchEverywhere<CR>
nmap <leader>f :action GotoFile<CR>

nmap <leader>r :action Run<CR>
nmap <leader>ds :action Debug<CR>
namp <leader>dS :action Stop<CR>
nmap <leader>dr :action Rerun<CR>
nmap <leader>dt :action ToggleLineBreakpoint<CR>
nmap <leader>dc :action Continue<CR>
nmap <leader>dn :action StepOver<CR>
nmap <leader>di :action StepInto<CR>
nmap <leader>do :action StepOut<CR>

" Handlers
sethandler <C-2> a:vim
sethandler <C-S-2> a:vim
sethandler <C-6> a:vim
sethandler <C-S-6> a:vim
sethandler <C-A> a:vim
sethandler <C-B> a:vim
sethandler <C-D> a:vim
sethandler <C-E> a:ide
sethandler <C-F> a:vim
sethandler <C-G> a:vim
sethandler <C-H> a:vim
sethandler <C-I> a:vim
sethandler <C-J> a:ide
sethandler <C-K> a:ide
sethandler <C-L> a:ide
sethandler <C-M> a:vim
sethandler <C-N> a:vim
sethandler <C-O> a:vim
sethandler <C-P> a:vim
sethandler <C-R> a:vim
sethandler <C-S> a:ide
sethandler <C-T> a:vim
sethandler <C-U> a:vim
sethandler <C-W> a:vim
sethandler <C-X> a:vim
sethandler <C-Y> a:vim
sethandler <C-[> a:vim
sethandler <C-\> a:vim
sethandler <C-]> a:vim
sethandler <C-C> a:vim
sethandler <C-V> a:vim
